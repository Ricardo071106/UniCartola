# Campus League — Environment Variables
# Banco — Supabase (Render: use Session pooler, NÃO Direct connection)
# Supabase → Database → Connection string → Session pooler → URI
DATABASE_URL=postgresql://postgres.SEU_PROJECT_REF:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Se usar Direct URL (db.xxx.supabase.co), defina a região do projeto:
# SUPABASE_REGION=sa-east-1

# Ou cole a URI completa do Session pooler aqui (tem prioridade):
# DATABASE_POOLER_URL=postgresql://postgres.xxx:senha@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# === LOGIN (obrigatório no Render — não existe "entrar como dev" em produção) ===
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# === OPCIONAL ===
# Cron que atualiza jogos da NDU (só se configurar Cron Job no Render)
CRON_SECRET=uma_senha_forte_qualquer

# Analytics (pode deixar vazio)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
