# === OBRIGATÓRIO ===
# Postgres — Render: use "Internal Database URL" (NÃO External)
# Supabase no Render: use Pooler, porta 6543 (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# === LOGIN (obrigatório no Render — não existe "entrar como dev" em produção) ===
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# === OPCIONAL ===
# Cron que atualiza jogos da NDU (só se configurar Cron Job no Render)
CRON_SECRET=uma_senha_forte_qualquer

# Analytics (pode deixar vazio)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
