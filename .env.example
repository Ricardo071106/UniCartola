# Database (docker-compose postgres on port 54322)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Supabase Auth (optional — dev mode works without)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PostHog analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Cron scrape protection
CRON_SECRET=change-me-in-production

# Scraper worker interval (ms)
SCRAPER_INTERVAL_MS=3600000
