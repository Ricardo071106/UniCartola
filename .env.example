# Opção A: URI do Session pooler (Supabase → Database → Session pooler → URI)
DATABASE_URL=postgresql://postgres.SEU_REF:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Opção B: variáveis separadas (evita problemas com senha na URL)
# SUPABASE_PROJECT_REF=seu_ref
# SUPABASE_POOLER_HOST=aws-0-sa-east-1.pooler.supabase.com
# SUPABASE_DB_PASSWORD=sua_senha

# Se só tiver Direct URL, defina a região para auto-converter ao pooler:
# SUPABASE_REGION=sa-east-1

SESSION_SECRET=change-me-to-a-long-random-string-in-production
NEXT_PUBLIC_APP_URL=http://localhost:3000
