# ═══════════════════════════════════════════════════════════════
# CAMPUS LEAGUE — Render (Environment) ou .env.local
# ═══════════════════════════════════════════════════════════════

# ── BANCO ─────────────────────────────────────────────────────
#
# Senha: Supabase → Project Settings → Database → Reset password
#
# RENDER — obrigatório se usar URL Direct (db.xxx.supabase.co):
SUPABASE_REGION=us-west-2

# RENDER — Opção 1: Direct + SUPABASE_REGION (converte para pooler no start)
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.tbwvsbpabadfjsjofgph.supabase.co:5432/postgres

# RENDER — Opção 2: Session pooler direto (copie do Supabase)
# DATABASE_URL=postgresql://postgres.tbwvsbpabadfjsjofgph:[SUA_SENHA]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# ── SESSÃO ────────────────────────────────────────────────────
SESSION_SECRET=[openssl rand -base64 48]

# ── APP ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://seu-app.onrender.com

# ── NDU (scraper automático) ──────────────────────────────────
# Fonte: https://www.ndu.com.br/jogos
# Gere com: openssl rand -base64 32
CRON_SECRET=[openssl rand -base64 32]

# ── LIMPAR BANCO (zerar dados, manter projeto) ────────────────
# npm run db:drop && npm run db:migrate && RUN_DB_SEED=1 npm run db:seed

# ── PRIMEIRO DEPLOY ───────────────────────────────────────────
# RUN_DB_SEED=1  (dados demo — NÃO use se quiser dados reais da NDU)
# No start do Render, o scraper NDU roda em background (não bloqueia o deploy)
# SKIP_NDU_SCRAPE=1 para desligar
# SKIP_NDU_SCRAPE=1
# NDU_SYNC_MATCH_SCORERS=1  (artilheiros por página de resultado — lento)
# NDU_SCORER_LIMIT=25
# Fontes: boletim PDF + jogos + estatisticas.ndu.com.br + logos em atletica

# ── LOCAL (Direct funciona no Mac) ────────────────────────────
# DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.tbwvsbpabadfjsjofgph.supabase.co:5432/postgres
# NEXT_PUBLIC_APP_URL=http://localhost:3000
