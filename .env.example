# ═══════════════════════════════════════════════════════════════
# CAMPUS LEAGUE — copie para .env.local (dev) ou Render (prod)
# ═══════════════════════════════════════════════════════════════

# ── 1. BANCO (Supabase Direct Connection) ─────────────────────
#
# Onde achar:
#   Supabase → Database → Connection string → Direct connection → URI
#
# Se não souber a senha:
#   Supabase → Project Settings → Database → Reset database password
#
# Troque:
#   [SUA_SENHA]        → senha do banco (resetada no Supabase)
#   [SEU_PROJECT_REF]  → ref do projeto (ex: tbwvsbpabadfjsjofgph)
#
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres

# ── 2. SESSÃO (obrigatório) ───────────────────────────────────
#
# Gere com: openssl rand -base64 48
#
SESSION_SECRET=[COLE_UMA_STRING_LONGA_ALEATORIA_AQUI]

# ── 3. URL DO APP ─────────────────────────────────────────────
#
# Local:
NEXT_PUBLIC_APP_URL=http://localhost:3000
#
# Render (troque pelo seu domínio):
# NEXT_PUBLIC_APP_URL=https://campus-league.onrender.com

# ── 4. PRIMEIRO DEPLOY (opcional, só uma vez) ─────────────────
# RUN_DB_SEED=1

# ── 5. PULAR MIGRATE (só emergência) ──────────────────────────
# SKIP_DB_MIGRATE=1
